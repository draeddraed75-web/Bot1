# متغيرات البيئة لمنصة سُراد (Sorad Streaming Platform)
# انسخ هذا الملف إلى .env وعدّل القيم

# ============================
# قاعدة البيانات (Database)
# ============================
# يتم توفيره تلقائياً من Replit عند استخدام PostgreSQL المدمج
DATABASE_URL=postgresql://user:password@localhost:5432/sorad

# ============================
# المصادقة (Authentication)
# ============================
# مفتاح سري قوي لتوقيع رموز JWT - غيّر هذا في الإنتاج!
JWT_SECRET=sorad-super-secret-key-change-in-production-min-32-chars

# ============================
# شبكة CDN (Content Delivery)
# ============================
# TODO: استبدل بـ CloudFront أو CDN حقيقي في الإنتاج
# TODO: استخدم CloudFront Signed URLs لأمان روابط الفيديو
CDN_BASE_URL=

# ============================
# بوابة الدفع (Payment Gateway)
# ============================
# TODO: احصل على مفتاح Stripe من https://dashboard.stripe.com
# TODO: أو استخدم بوابة دفع عربية: PayTabs, HyperPay, Tap Payments
STRIPE_KEY_PLACEHOLDER=sk_test_your_stripe_key_here

# ============================
# PORT (المنافذ)
# ============================
# يتم تعيينه تلقائياً من Replit
PORT=3000
